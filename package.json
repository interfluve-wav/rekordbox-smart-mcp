{
  "name": "rekordbox-smart-mcp",
  "version": "1.0.0",
  "description": "Production-ready MCP server for Pioneer Rekordbox DJs – smart playlists, setlist analysis, undo system",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rekordbox",
    "dj",
    "playlist",
    "music",
    "harmonic-mixing",
    "mixing",
    "setlist"
  ],
  "author": "interfluve-wav",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interfluve-wav/rekordbox-smart-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/interfluve-wav/rekordbox-smart-mcp/issues"
  },
  "homepage": "https://github.com/interfluve-wav/rekordbox-smart-mcp#readme",
  "main": "dist/index.js",
  "bin": {
    "rekordbox-smart-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "rekordbox-smart-mcp.toml",
    "mcp.json.example",
    "README.md",
    "QUICKSTART.md",
    "SMARTFEATURES.md",
    "Examples.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/ui && cp src/ui/*.html dist/ui/ && cp -f src/ui/tool-catalog.json dist/ui/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:smoke": "tsx scripts/smoke-tools.mts",
    "test:rekordbox-fixture": "PATH=\"$PWD/TEST DB/.venv/bin:$PATH\" npx tsx \"TEST DB/run-rekordbox-fixture-tests.mts\"",
    "test:mcp-all-tools": "PATH=\"$PWD/TEST DB/.venv/bin:$PATH\" npx tsx scripts/run-all-mcp-tools.mts",
    "ui:preview": "npm run build && node scripts/serve-ui.mjs"
  },
  "keywords": [
    "mcp",
    "rekordbox",
    "dj",
    "music",
    "metadata"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "fast-xml-parser": "^4.3.2",
    "music-metadata": "^8.1.4",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
